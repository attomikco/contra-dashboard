# Copy this to .env.local and fill in real values when you wire up Supabase.
# Until then the app runs fine on mock data from src/lib/mock-data.ts.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — only for server-side actions that need elevated privileges.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
